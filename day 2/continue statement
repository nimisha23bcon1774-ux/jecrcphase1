//Problem 5 - Continue Statement
// Print 1 to n and avoid those number which are divisible by 3
#include <iostream>
using namespace std;

int main()
{
    int n;
    cin >> n;
    
    for(int i =1;i <= n;i++)
    {
        if( i % 3 == 0)
        {
            continue;
        }
        cout << i << " ";
    }
    cout << "\n";
    return 0;
}
