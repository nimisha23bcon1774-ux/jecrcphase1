//PROBLEM 9 - prime number or not
#include<iostream>
using namespace std;

int main()
{
    int n;
    cin>>n;
    bool isPrime = true;
    
    if(n < 2)
    {
       isPrime = false; 
    }else
    {
        for(int i = 2;i < n;i ++)
        {
            if(n % i == 0)
            {
                isPrime = false;
                break;
            }
        }
    }
       if(isPrime)
       {
           cout << "PRIME NUMBER";
       }
       else
       {
           cout << "NOT A PRIME NUMBER";
       }
        return 0;
}
