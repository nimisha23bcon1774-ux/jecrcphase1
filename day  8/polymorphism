#include<iostream>
using namespace std;

class Parent
{
    public:
        virtual void sum(int a, int b)
        {
            cout << a+b<<"parent";
        }
};

class child : public Parent
{
    public:
         void sum(int a, int b)
         {
             cout << a+b  << " \n child";
         }
};



int main()
{
    
    child c;
    c.sum(10,20);
}
