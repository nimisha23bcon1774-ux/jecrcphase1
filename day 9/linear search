#include<iostream>
using namespace std;
//Linear Search

int LinearSearch(int arr[], int size,int TargetValue)
{
    for(int i = 0; i < size; i++)
    {
        if (arr[i] == TargetValue)
        {
            return i;
        }
    }
    return -1;
}

int main ()
{
    int arr[] = {10,20,30,40,50};;
    int targetIndex = LinearSearch(arr,5,40);
    cout << targetIndex;
}
